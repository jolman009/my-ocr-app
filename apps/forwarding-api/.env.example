# Manifest 956 forwarding-api — local development env
#
# Copy to apps/forwarding-api/.env and fill in real values.
# Both apps/api and apps/forwarding-api point at the SAME Supabase database
# in dev, so DATABASE_URL and JWT_SECRET should match apps/api/.env exactly.
# PORT must differ from apps/api (4000) so the two services can run
# side by side.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/receipt_ocr?pgbouncer=true"
DIRECT_URL=""
PORT=4001
JWT_SECRET="development-secret"
WEB_ORIGIN="http://localhost:5173"
WEB_ORIGINS="http://localhost:5173,http://localhost:8081"
AUTH_REQUIRED="false"

# OCR + storage config (consumed by apps/api's providers imported via
# @receipt-radar/api/*). Keep in sync with apps/api/.env.
OCR_PROVIDER="mock"
STORAGE_PROVIDER="local"
UPLOAD_DIR="uploads"

# Only required when OCR_PROVIDER=google-vision
GOOGLE_APPLICATION_CREDENTIALS=""
GOOGLE_CLIENT_EMAIL=""
GOOGLE_PRIVATE_KEY=""

# Only required when STORAGE_PROVIDER=s3
AWS_REGION="us-east-1"
S3_BUCKET=""
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE_URL=""
