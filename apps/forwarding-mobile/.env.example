# Manifest 956 mobile — local development env
#
# Copy to apps/forwarding-mobile/.env and edit for your setup.
# Expo auto-picks up .env files at start. EAS build profiles (see eas.json)
# override these for preview / production.
#
# Android emulator → host machine: 10.0.2.2
# iOS simulator   → host machine: localhost
# Physical device → your dev machine's LAN IP (e.g. 192.168.1.42)

# Receipt Radar API (login lives here — both apps share JWT_SECRET)
EXPO_PUBLIC_AUTH_API_URL=http://10.0.2.2:4000/api

# Manifest 956 forwarding API (shipment document operations)
EXPO_PUBLIC_FORWARDING_API_URL=http://10.0.2.2:4001/forwarding
