DATABASE_URL="postgresql://postgres:postgres@localhost:5432/receipt_ocr"
PORT=4000
WEB_ORIGIN="http://localhost:5173"
WEB_ORIGINS="http://localhost:5173,http://localhost:8081"
OCR_PROVIDER="mock"
GOOGLE_APPLICATION_CREDENTIALS=""
UPLOAD_DIR="uploads"
AUTH_REQUIRED="false"
JWT_SECRET="development-secret"
STORAGE_PROVIDER="local"
AWS_REGION="us-east-1"
S3_BUCKET=""
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# MUST end with the bucket name (e.g. ".../public/receipts"). Keys are written as
# `receipts/<file>` and the public URL is `${S3_PUBLIC_BASE_URL}/<key>`; omitting
# the bucket segment makes every uploaded image 404 despite a successful upload.
S3_PUBLIC_BASE_URL=""
